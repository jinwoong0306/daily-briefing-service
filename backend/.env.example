APP_NAME=Daily Briefing API
API_PREFIX=/api/v1
APP_ENV=prod
DATABASE_URL=postgresql+psycopg://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require
AUTO_CREATE_TABLES=false
JWT_SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
KEYWORD_MIN_COUNT=1
KEYWORD_MAX_COUNT=3
CACHE_TTL_SECONDS=300
LOGIN_RATE_LIMIT_PER_MINUTE=10
AUTH_METRICS_WINDOW_SIZE=200
API_SETTINGS_METRICS_WINDOW_SIZE=200
REDIS_URL=redis://default:password@localhost:6379
REDIS_SCAN_COUNT=200
INGEST_ADMIN_EMAILS=
INGEST_SCHEDULER_ENABLED=false
INGEST_SCHEDULER_INTERVAL_MINUTES=5
INGEST_BATCH_MATCH=briefing:*
INGEST_BATCH_PER_KEY_LIMIT=30
INGEST_BATCH_MAX_KEYS=10
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
