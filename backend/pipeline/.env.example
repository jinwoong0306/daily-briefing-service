OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
NAVER_CLIENT_ID="YOUR_NAVER_CLIENT_ID"
NAVER_CLIENT_SECRET="YOUR_NAVER_CLIENT_SECRET"

# Supabase (서버 전용 Service Role Key 사용)
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Optional
SUPABASE_ARTICLES_TABLE="articles"
SUPABASE_ARTICLES_CONFLICT_COL="url"
SUPABASE_USER_KEYWORDS_TABLE="user_keywords"
SUPABASE_PUSH_TOKENS_TABLE="user_push_tokens"

# Optional (clustering.py 결과 업로드용)
# 기본값은 SUPABASE_ARTICLES_TABLE (articles)
SUPABASE_CLUSTERED_TABLE="articles"
SUPABASE_CLUSTERED_CONFLICT_COL="url"

# Batch runtime controls
PIPELINE_NAME="unified_crawler"
PIPELINE_WINDOW_OVERLAP_MINUTES="10"
PIPELINE_LOCK_FILE="/tmp/news_pipeline.lock"
PIPELINE_COLLECTION_START_HOUR="20"
PIPELINE_COLLECTION_END_HOUR="6"
COLLECTOR_PIPELINE_NAME="collector_unified"
FINALIZER_PIPELINE_NAME="finalize_briefing"

# Redis temporary briefing cache
REDIS_URL="rediss://default:YOUR_UPSTASH_TOKEN@YOUR_UPSTASH_HOST.upstash.io:6379"
BRIEFING_REDIS_TTL_SECONDS="172800"
BRIEFING_CANDIDATE_LIMIT="30"
BRIEFING_MIN_ITEMS_PER_KEYWORD="3"
BRIEFING_MAX_ITEMS_PER_KEYWORD="5"
BRIEFING_SELECTION_PREVIEW_CHARS="600"
BRIEFING_SUMMARY_CONTENT_CHARS="4000"
THUMBNAIL_FETCH_TIMEOUT_SECONDS="5"
OPENAI_BRIEFING_MODEL="gpt-5-nano"
OPENAI_BRIEFING_REASONING_EFFORT="low"
OPENAI_BRIEFING_VERBOSITY="low"
OPENAI_SELECTION_MAX_TOKENS="800"
OPENAI_SUMMARY_MAX_TOKENS="3000"

# App push placeholder controls
PUSH_TITLE="오늘의 맞춤 뉴스 브리핑"
PUSH_BODY="관심 키워드의 새 브리핑이 도착했습니다."
